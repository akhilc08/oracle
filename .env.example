# Oracle Environment Variables

# --- Infrastructure (required) ---
ORACLE_NEO4J_URI=bolt://localhost:7687
ORACLE_NEO4J_USER=neo4j
ORACLE_NEO4J_PASSWORD=oracle_dev_password
ORACLE_QDRANT_HOST=localhost
ORACLE_QDRANT_PORT=6333

# --- Required API keys ---
ORACLE_ANTHROPIC_API_KEY=your_anthropic_key_here     # console.anthropic.com
ORACLE_NEWSAPI_KEY=your_newsapi_key_here              # newsapi.org (free tier works)

# --- Optional: additional ingestion sources ---
# Twitter/X real-time streaming
ORACLE_TWITTER_BEARER_TOKEN=

# Reddit sentiment
ORACLE_REDDIT_CLIENT_ID=
ORACLE_REDDIT_CLIENT_SECRET=

# US Congress bill tracking (free — api.congress.gov)
ORACLE_CONGRESS_API_KEY=

# Court opinions (free — courtlistener.com)
ORACLE_COURTLISTENER_API_KEY=

# Audio/Whisper transcription model size (base|small|medium|large)
ORACLE_WHISPER_MODEL_SIZE=base
